# =====================================================================
# .gitignore do monorepo OS-ALS
# Cobre as duas stacks: Next.js (app-osals.nextjs) e Spring Boot
# (api-osals.java). Cada subprojeto mantem o seu proprio .gitignore;
# este arquivo da raiz e completo e funciona por conta propria.
# =====================================================================

# ---------------------------------------------------------------------
# Ambientes e segredos
# ---------------------------------------------------------------------
.env
.env.local
.env.*.local
.env.prod
!.env.example
!.env.local.example
!.env.prod.example

# Chaves (JWT RS256, certificados)
keys/
*.pem
*.key
*.p12
*.jks

# ---------------------------------------------------------------------
# Node.js / Next.js
# ---------------------------------------------------------------------
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Build e cache do Next.js
.next/
out/
build/
dist/
.turbo/
.swc/

# Testes
coverage/

# TypeScript
*.tsbuildinfo
next-env.d.ts

# Logs do gerenciador de pacotes
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Deploy
.vercel

# ---------------------------------------------------------------------
# Java / Spring Boot / Maven
# ---------------------------------------------------------------------
target/
!**/src/main/**/target/
!**/src/test/**/target/
*.class
HELP.md
dependency-reduced-pom.xml

# Maven Wrapper (o jar e baixado; os scripts mvnw sao versionados)
.mvn/wrapper/maven-wrapper.jar

# Gradle (caso seja usado)
.gradle/
!**/src/main/**/build/
!**/src/test/**/build/

# ---------------------------------------------------------------------
# Logs e anexos locais
# ---------------------------------------------------------------------
logs/
*.log
anexos-local/

# ---------------------------------------------------------------------
# IDEs e editores — o projeto e desenvolvido em VS Code e IntelliJ IDEA
# ---------------------------------------------------------------------
# IntelliJ IDEA — ignora a config local da IDE por inteiro
.idea/
*.iml
*.iws
*.ipr

# VS Code — ignora o ruido local, mas permite versionar a config
# compartilhada do time (extensoes recomendadas, tasks, launch, etc.)
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
!.vscode/*.code-snippets
*.code-workspace
.history/

# ---------------------------------------------------------------------
# Claude Code — configuracao local do agente
# ---------------------------------------------------------------------
.claude/

# ---------------------------------------------------------------------
# Sistema operacional
# ---------------------------------------------------------------------
.DS_Store
Thumbs.db
desktop.ini

# ---------------------------------------------------------------------
# Docker
# ---------------------------------------------------------------------
docker-compose.override.yml
