<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <property name="LOGS_DIR" value="${LOGS_DIR:-./logs}"/>

    <!-- Arquivo principal: rotacao diaria, retencao 30 dias, gzip dos arquivos rotacionados -->
    <appender name="ARQUIVO" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOGS_DIR}/os-als.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOGS_DIR}/os-als.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
            <maxHistory>30</maxHistory>
            <totalSizeCap>1GB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Arquivo dedicado a SQL/Hibernate: separado para estudo, rotacao propria.
         Recebe o SQL gerado (org.hibernate.SQL), os parametros (org.hibernate.orm.jdbc.bind)
         e as consultas lentas (org.hibernate.SQL_SLOW). -->
    <appender name="ARQUIVO_SQL" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOGS_DIR}/os-als-sql.log</file>
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">
            <fileNamePattern>${LOGS_DIR}/os-als-sql.%d{yyyy-MM-dd}.log.gz</fileNamePattern>
            <maxHistory>14</maxHistory>
            <totalSizeCap>500MB</totalSizeCap>
        </rollingPolicy>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Console: util para `docker-compose logs -f backend` -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss.SSS} %-5level %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="ARQUIVO"/>
        <appender-ref ref="CONSOLE"/>
    </root>

    <logger name="br.com.osals" level="INFO"/>

    <!-- Loggers de SQL: o NIVEL e controlado pelo application.yml (env HIBERNATE_SQL_LEVEL,
         HIBERNATE_BIND_LEVEL). Aqui so isolamos a SAIDA no arquivo dedicado (additivity=false),
         para nao poluir o log da aplicacao nem o console. -->
    <logger name="org.hibernate.SQL" additivity="false">
        <appender-ref ref="ARQUIVO_SQL"/>
    </logger>
    <logger name="org.hibernate.orm.jdbc.bind" additivity="false">
        <appender-ref ref="ARQUIVO_SQL"/>
    </logger>
    <!-- Consultas lentas tambem vao ao console, para aparecerem no `docker logs`. -->
    <logger name="org.hibernate.SQL_SLOW" additivity="false">
        <appender-ref ref="ARQUIVO_SQL"/>
        <appender-ref ref="CONSOLE"/>
    </logger>

    <logger name="com.zaxxer.hikari" level="WARN"/>
    <logger name="org.springframework.transaction" level="WARN"/>
    <logger name="org.springframework.boot.autoconfigure" level="WARN"/>
    <logger name="org.springframework.security" level="INFO"/>

</configuration>
