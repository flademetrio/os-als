# =====================================================================
# Variaveis de ambiente do api-osals.
# Copie este arquivo para `.env` e ajuste os valores.
# NUNCA commitar o `.env` real com segredos.
# =====================================================================

# --- Banco ---
# Em Docker Compose (servico backend), o host e "postgres" e a porta e 5432.
# Em dev nativo (./mvnw spring-boot:run), o host e "localhost" e a porta e 5433
# (5433 no host evita conflito com PostgreSQL nativo do Windows na 5432).
BD_URL=jdbc:postgresql://postgres:5432/osals
BD_USUARIO=osals
BD_SENHA=osals-dev
BD_NOME=osals

# --- Aplicacao ---
APP_PORTA=8080
APP_URL_BASE=http://localhost:8080
FRONTEND_URL=http://localhost:3000

# --- JWT (RS256) ---
# Gerar chaves com:
#   cd api-osals.java
#   mkdir -p keys
#   openssl genrsa -out keys/chave-privada.pem 2048
#   openssl rsa -in keys/chave-privada.pem -pubout -out keys/chave-publica.pem
# As chaves ficam em ./keys/ (gitignored).
JWT_CHAVE_PRIVADA_CAMINHO=./keys/chave-privada.pem
JWT_CHAVE_PUBLICA_CAMINHO=./keys/chave-publica.pem
JWT_EMISSOR=os-als
JWT_AUDIENCE=tenant
JWT_EXPIRACAO_MINUTOS=1440
JWT_REFRESH_EXPIRACAO_DIAS=30

# --- Seguranca ---
BCRYPT_FORCA=10
LOGIN_MAX_TENTATIVAS=5
LOGIN_BLOQUEIO_MINUTOS=15

# --- CORS ---
CORS_ORIGENS_PERMITIDAS=http://localhost:3000
CORS_METODOS_PERMITIDOS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_HEADERS_PERMITIDOS=Authorization,Content-Type

# --- Anexos ---
ANEXOS_DIR=/var/os-als/anexos
ANEXO_TAMANHO_MAX_MB=10

# --- Logs ---
LOGS_DIR=/var/log/os-als

# --- Custos (defaults iniciais — admin altera depois via UI) ---
MARKUP_PADRAO=30.00
VALOR_KM_CENTAVOS_PADRAO=150

# --- Bootstrap do admin inicial (primeira inicializacao apenas) ---
BOOTSTRAP_ADMIN_EMAIL=flavio@alsindustria.com.br
BOOTSTRAP_ADMIN_SENHA=123
BOOTSTRAP_ADMIN_NOME=Flavio
