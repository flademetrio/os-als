# =====================================================================
# Configuracao de PRODUCAO do OS-ALS.
#
# Copie este arquivo para .env.prod (que e gitignored) e ajuste TODOS os
# valores marcados com TROCAR.
#
# NUNCA reuse senhas e chaves de desenvolvimento em producao.
# NUNCA commite .env.prod no git.
# =====================================================================

# ---------------------------------------------------------------------
# Versao das imagens a rodar.
# Use a tag de release exata (v1.0.0, v1.0.1...) para ter rollback
# determinístico. "latest" funciona, mas dificulta rollback.
# ---------------------------------------------------------------------
OSALS_VERSAO=latest

# ---------------------------------------------------------------------
# Banco de dados
# ---------------------------------------------------------------------
BD_USUARIO=osals
BD_SENHA=TROCAR-POR-SENHA-FORTE
BD_NOME=osals

# ---------------------------------------------------------------------
# Aplicacao (backend)
# ---------------------------------------------------------------------
APP_PORTA=8080
APP_URL_BASE=http://localhost:8080
# Coloque o IP/host que o frontend vai ter para o usuario
FRONTEND_URL=http://192.168.0.100:3000

# ---------------------------------------------------------------------
# JWT (RS256) — gere um par NOVO no servidor (instrucoes no compose.prod)
# Os caminhos sao dentro do container (montados de /srv/os-als/keys).
# ---------------------------------------------------------------------
JWT_CHAVE_PRIVADA_CAMINHO=/app/keys/chave-privada.pem
JWT_CHAVE_PUBLICA_CAMINHO=/app/keys/chave-publica.pem
JWT_EMISSOR=os-als
JWT_AUDIENCE=tenant
JWT_EXPIRACAO_MINUTOS=1440
JWT_REFRESH_EXPIRACAO_DIAS=30

# ---------------------------------------------------------------------
# Seguranca
# ---------------------------------------------------------------------
BCRYPT_FORCA=12
LOGIN_MAX_TENTATIVAS=5
LOGIN_BLOQUEIO_MINUTOS=15

# ---------------------------------------------------------------------
# CORS — host(es) que o frontend usa
# ---------------------------------------------------------------------
CORS_ORIGENS_PERMITIDAS=http://192.168.0.100:3000
CORS_METODOS_PERMITIDOS=GET,POST,PUT,DELETE,PATCH,OPTIONS
CORS_HEADERS_PERMITIDOS=Authorization,Content-Type

# ---------------------------------------------------------------------
# Anexos (bind mount em /srv/os-als/anexos no host)
# ---------------------------------------------------------------------
ANEXOS_DIR=/var/os-als/anexos
ANEXO_TAMANHO_MAX_MB=10

# ---------------------------------------------------------------------
# Logs (bind mount em /srv/os-als/logs no host)
# ---------------------------------------------------------------------
LOGS_DIR=/var/log/os-als

# ---------------------------------------------------------------------
# Custos — defaults usados se o admin nao tiver alterado pela UI
# ---------------------------------------------------------------------
MARKUP_PADRAO=30.00
VALOR_KM_CENTAVOS_PADRAO=150

# ---------------------------------------------------------------------
# Bootstrap do admin (criado APENAS na primeira inicializacao com
# usuario==0 no banco). Apos o primeiro login, troque a senha pela UI.
# ---------------------------------------------------------------------
BOOTSTRAP_ADMIN_EMAIL=admin@alsindustria.com.br
BOOTSTRAP_ADMIN_SENHA=TROCAR-NA-PRIMEIRA-INICIALIZACAO
BOOTSTRAP_ADMIN_NOME=Administrador
