# =====================================================================
# Variaveis de ambiente do app-osals.nextjs (frontend).
# Copie para `.env.local` (que e gitignored automaticamente pelo Next).
# NUNCA prefixar com NEXT_PUBLIC_ valores sensiveis.
# =====================================================================

# URL do backend (server-only — usado em Server Components e Server Actions)
API_BASE_URL=http://localhost:8080

# JWT — para validacao criptografica em Server Components (camada 2).
# Caminho relativo ao arquivo PEM da chave publica (copia da do backend).
# Em dev: cp api-osals.java/keys/chave-publica.pem app-osals.nextjs/keys/
JWT_CHAVE_PUBLICA_CAMINHO=./keys/chave-publica.pem

# Devem bater com os mesmos valores do back
JWT_EMISSOR=os-als
JWT_AUDIENCE=tenant

# Cookies com flag Secure (so funcionam em HTTPS — localhost e excecao).
# Deixe vazio/false em on-premise HTTP. Habilite quando subir HTTPS.
COOKIES_SECURE=false
